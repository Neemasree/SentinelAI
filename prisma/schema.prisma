// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      Role     @default(DEVELOPER)
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  apiKeys   ApiKey[]
  auditLogs AuditLog[]

  @@map("users")
}

enum Role {
  ADMIN
  DEVELOPER
  VIEWER
}

model ApiKey {
  id              String   @id @default(cuid())
  userId          String
  name            String
  key             String   @unique
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  lastUsedAt      DateTime?
  usageCount      Int      @default(0)
  currentLimit    Int      @default(70)
  remainingTokens Int      @default(70)

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  requestLogs   RequestLog[]
  forecasts     ForecastRecord[]
  adjustments   PredictiveAdjustment[]
  incidents     Incident[]

  @@index([userId])
  @@map("api_keys")
}

model RequestLog {
  id        String   @id @default(cuid())
  apiKeyId  String
  timestamp DateTime @default(now())
  service   String
  endpoint  String
  method    String
  status    Int
  latencyMs Int
  ip        String
  client    String

  apiKey ApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@index([apiKeyId])
  @@index([timestamp])
  @@map("request_logs")
}

model ForecastRecord {
  id            String   @id @default(cuid())
  apiKeyId      String
  timestamp     DateTime @default(now())
  service       String
  currentRate   Float
  predictedRate Float
  confidence    Float
  limitChanged  Boolean

  apiKey ApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@index([apiKeyId])
  @@index([timestamp])
  @@map("forecast_records")
}

model PredictiveAdjustment {
  id            String   @id @default(cuid())
  apiKeyId      String
  timestamp     DateTime @default(now())
  service       String
  oldLimit      Int
  newLimit      Int
  predictedRate Float
  slope         Float
  explanation   String?

  apiKey ApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@index([apiKeyId])
  @@index([timestamp])
  @@map("predictive_adjustments")
}

model Incident {
  id          String   @id @default(cuid())
  apiKeyId    String
  timestamp   DateTime @default(now())
  service     String
  failureRate Float
  explanation String?

  apiKey ApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@index([apiKeyId])
  @@index([timestamp])
  @@map("incidents")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  resource  String
  oldValue  String?
  newValue  String?
  timestamp DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([timestamp])
  @@map("audit_logs")
}
